{
  "name": "quetz",
  "version": "0.1.0",
  "description": "The Feathered Serpent Dev Loop — wraps Claude Code into a self-feeding development loop",
  "main": "dist/cli.js",
  "bin": {
    "quetz": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "claude",
