{
  "name": "@dkchar/quetz",
  "version": "0.5.1",
  "description": "The Feathered Serpent Dev Loop — a self-feeding issue resolution agentic loop.",
  "main": "dist/cli.js",
  "type": "commonjs",
  "exports": "./dist/cli.js",
  "bin": {
    "quetz": "dist/cli.js"
  },
