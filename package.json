    "automation",
    "developer-tools",
    "beads"
  ],
  "author": "Dhruv Krishnamachari",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@octokit/rest": "^20.1.1",
    "chalk": "^5.3.0",
    "handlebars": "^4.7.8",
    "ink": "^5.2.1",
    "react": "^18.3.1",
    "yaml": "^2.4.5"
  },
  "devDependencies": {
    "@types/handlebars": "^4.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.28",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.0"
  }
